{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data including preferences and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID from Firebase Auth." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "URL to user's profile picture." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role for RBAC." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Game": {
      "title": "Chess Game",
      "description": "A saved chess game with PGN and metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique game ID." },
        "ownerId": { "type": "string", "description": "UID of the user who saved the game." },
        "pgn": { "type": "string", "description": "The PGN string of the game." },
        "title": { "type": "string", "description": "Optional title for the game." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the game was saved." }
      },
      "required": ["ownerId", "pgn", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Collection of saved chess games."
    }
  }
}
